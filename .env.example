# Development Mode
# Установите DEV_MODE=1 для локальной разработки с polling
# Оставьте пустым или установите 0 для продакшен режима с webhook
DEV_MODE=1

# Telegram Bot Token
# Получите токен от @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Admin chat (для алертов/отчётов scheduled jobs)
# Узнайте ID чата через /getid или логи бота
ADMIN_CHAT_ID=

# Telegraph / Telegram web preview (optional)
# Operator reports (Smart Update details) use `disable_web_page_preview=True` to stay compact,
# so Telegram won't prefetch Telegraph pages from those messages.
#
# If you want pages to be "ready in Telegram cache" right after publish:
# - validate image URLs before publishing (drops/replaces broken ones)
# - (optionally) warm up Telegram web preview right after page publish
# Note: `telegra.ph/upload` is deprecated/unavailable — images are hosted in Supabase Storage (WebP).
# TELEGRAPH_VALIDATE_IMAGE_URLS=1
# TELEGRAPH_PREVIEW_WARMUP=1
# TELEGRAPH_PREVIEW_WARMUP_CHAT_ID=   # default: ADMIN_CHAT_ID
# TELEGRAPH_PREVIEW_WARMUP_DELETE_SEC=30

# Scheduler heavy-ops guard (recommended)
# Prevents parallel long-running jobs (manual vs scheduled). When a scheduled heavy job is skipped,
# the bot notifies `ADMIN_CHAT_ID`.
# SCHED_HEAVY_GUARD_MODE=skip   # skip | wait | off
# SCHED_HEAVY_TRY_TIMEOUT_SEC=0.2
# Legacy: extra in-scheduler serialization (implies guard_mode=wait)
# SCHED_SERIALIZE_HEAVY_JOBS=0

# Persistent runtime logs on machine disk (optional, useful for prod incident review)
# Writes the existing root logger stream into hourly-rotated files and keeps about one day.
ENABLE_RUNTIME_FILE_LOGGING=0
RUNTIME_LOG_DIR=/data/runtime_logs
RUNTIME_LOG_BASENAME=events-bot.log
RUNTIME_LOG_RETENTION_HOURS=24
# Optional: override file handler level independently from the console/root level.
# RUNTIME_LOG_LEVEL=INFO

# OpenAI API Token (для LLM операций)
# FOUR_O_TOKEN=sk-...

# Event parsing backend (VK/TG text -> structured drafts)
# По умолчанию используется Gemma. Чтобы временно форсировать старый OpenAI-парсер:
# EVENT_PARSE_LLM=4o
# EVENT_PARSE_GEMMA_MODEL=gemma-3-27b-it
# EVENT_PARSE_GEMMA_MAX_TOKENS=2200

# Smart Update (sources → facts → text)
# Fact-first narrative generation (default: enabled). Rollback: set to 0.
# SMART_UPDATE_FACT_FIRST=1
# Optional: allow light emoji usage in full public descriptions (Telegraph/body).
# SMART_UPDATE_DESCRIPTION_EMOJI_MODE=light   # light | off
# SMART_UPDATE_DESCRIPTION_MAX_EMOJIS=3
# Far-future poster date guard (months ahead of today). Set to 0 to disable.
# SMART_UPDATE_FAR_FUTURE_REVIEW_MONTHS=6

# Google AI Studio (Gemma/Gemini)
GOOGLE_API_KEY=

# Telegram Monitoring / local Telethon runtime
TG_SESSION=
TG_API_ID=
TG_API_HASH=

# Kaggle API (для запуска kernels через API)
KAGGLE_USERNAME=
KAGGLE_KEY=
# KAGGLE_CONFIG_DIR=/path/to/kaggle/config

# Telegraph cache sanitizer schedule (опционально)
# Прогрев/проверка Telegram web preview (Instant View cached_page + preview photo) для Telegraph страниц
# через Kaggle/Telethon и постановка “битых” страниц на пересборку.
ENABLE_TELEGRAPH_CACHE_SANITIZER=0
TELEGRAPH_CACHE_TIME_LOCAL=01:10
TELEGRAPH_CACHE_TZ=Europe/Kaliningrad
# Tuning (optional):
# TELEGRAPH_CACHE_DAYS_BACK=7
# TELEGRAPH_CACHE_DAYS_FORWARD=120
# TELEGRAPH_CACHE_LIMIT_EVENTS=180
# TELEGRAPH_CACHE_LIMIT_FESTIVALS=80
# TELEGRAPH_CACHE_REPEATS=2
# TELEGRAPH_CACHE_ATTACH_WAIT_SEC=20
# TELEGRAPH_CACHE_PER_URL_TIMEOUT_SEC=35
# TELEGRAPH_CACHE_DELETE_MESSAGES=1
# TELEGRAPH_CACHE_REGEN_AFTER_RUNS=2
# TELEGRAPH_CACHE_ENQUEUE_REGEN=1
# If you keep multiple auth bundles (prod/dev/e2e), select which env key to use:
# TELEGRAPH_CACHE_AUTH_BUNDLE_ENV=TELEGRAM_AUTH_BUNDLE_S22

# Telegram Monitoring schedule (опционально)
ENABLE_TG_MONITORING=0
TG_MONITORING_TIME_LOCAL=23:40
TG_MONITORING_TZ=Europe/Kaliningrad
# TG_MONITORING_MISFIRE_GRACE_SECONDS=1800
# TG_MONITORING_CATCHUP_LOOKBACK_SECONDS=86400
# TG_MONITORING_DAYS_BACK=3
# If you want mature /popular_posts 7-day Telegram snapshots (age_day=6), raise this to at least 7.
# TG_MONITORING_TIMEOUT_MODE=dynamic
# TG_MONITORING_TIMEOUT_MINUTES=90
# TG_MONITORING_TIMEOUT_BASE_MINUTES=15
# TG_MONITORING_TIMEOUT_PER_SOURCE_MINUTES=3.64
# TG_MONITORING_TIMEOUT_SAFETY_MULTIPLIER=1.3
# TG_MONITORING_TIMEOUT_MAX_MINUTES=360
# /tg inline drain (best-effort): max seconds to wait for JobOutbox to build Telegraph/ICS per-post.
# TG_MONITORING_INLINE_DRAIN_TIMEOUT_SEC=10
# Cross-process lock file (опционально). Полезно, если на хосте может запуститься 2 polling-инстанса.
# По умолчанию: /tmp/eventsbot-<BOT_CODE>-tg-monitoring.lock
# TG_MONITORING_GLOBAL_LOCK_PATH=/tmp/eventsbot-announcements_test-tg-monitoring.lock

# Source parsing schedule (опционально)
ENABLE_SOURCE_PARSING=0
SOURCE_PARSING_TIME_LOCAL=04:30
SOURCE_PARSING_TZ=Europe/Kaliningrad
ENABLE_SOURCE_PARSING_DAY=0
SOURCE_PARSING_DAY_TIME_LOCAL=14:15
SOURCE_PARSING_DAY_TZ=Europe/Kaliningrad

# 3D previews schedule (опционально)
ENABLE_3DI_SCHEDULED=0
THREEDI_TIMES_LOCAL=07:15,15:15,17:15
THREEDI_TZ=Europe/Kaliningrad

# Guide excursions schedule (опционально)
ENABLE_GUIDE_EXCURSIONS_SCHEDULED=0
GUIDE_EXCURSIONS_LIGHT_TIMES_LOCAL=09:05,13:20
GUIDE_EXCURSIONS_FULL_TIME_LOCAL=20:10
GUIDE_EXCURSIONS_TZ=Europe/Kaliningrad
# Default Gemma 4 split for guide monitoring:
# GUIDE_MONITORING_SCREEN_MODEL=models/gemma-4-26b-a4b-it
# GUIDE_MONITORING_EXTRACT_MODEL=models/gemma-4-31b-it
# GUIDE_MONITORING_LLM_TIMEOUT_RETRIES=1
# GUIDE_MONITORING_LLM_PROVIDER_5XX_RETRIES=1
# GUIDE_OCCURRENCE_ENRICH_MODEL=gemma-4-31b
# GUIDE_EXCURSIONS_DEDUP_MODEL=gemma-4-31b
# GUIDE_DIGEST_WRITER_MODEL=gemma-4-31b
# Optional: APScheduler misfire window + critical catch-up lookback for the daily full slot.
# GUIDE_MONITORING_MISFIRE_GRACE_SECONDS=1800
# GUIDE_MONITORING_CATCHUP_LOOKBACK_SECONDS=86400
# Автопубликация нового дайджеста сразу после успешного scheduled full scan.
ENABLE_GUIDE_DIGEST_SCHEDULED=0
# Целевой канал для manual/scheduled guide digest publish.
GUIDE_DIGEST_TARGET_CHAT=@wheretogo39
# Где хранить materialized media для guide digest после import из Kaggle.
GUIDE_MEDIA_STORE_ROOT=/data/guide_media

# /v — автоматический production-first рендер "Завтра".
# Канонический slot: 16:45 local. При историческом GPU runtime ~1:45..2:40 это обычно
# даёт публикацию ближе к 19:00 и всё ещё оставляет буфер до guide full scan в 20:10.
ENABLE_V_TOMORROW_SCHEDULED=0
V_TOMORROW_TIME_LOCAL=16:45
V_TOMORROW_TZ=Europe/Kaliningrad
V_TOMORROW_PROFILE=default
# Tolerate short scheduler stalls around the slot before APScheduler marks the run as missed.
# V_TOMORROW_MISFIRE_GRACE_SECONDS=600
# If the process stays alive but the cron slot still does not fire, the watchdog dispatches
# the same scheduled path after this local-time grace window.
# V_TOMORROW_WATCHDOG_GRACE_SECONDS=720
# V_TOMORROW_WATCHDOG_INTERVAL_SECONDS=60
# Legacy alias route remains supported only for older env sets that still use the legacy enable flag.
# It should not be used to override the canonical production slot above.
# ENABLE_V_TEST_TOMORROW_SCHEDULED=0
# V_TEST_TOMORROW_TIME_LOCAL=16:45
# V_TEST_TOMORROW_TZ=Europe/Kaliningrad
# V_TEST_TOMORROW_PROFILE=default
# Optional: force scheduled slot back into legacy test-render mode.
# V_TOMORROW_TEST_MODE=0
# VIDEO_KAGGLE_TIMEOUT_MINUTES=225
# Optional: publish `/v` stories directly from Kaggle after a successful render.
# Prefer explicit ordered targets for production fanout; `main`-channel order is only fallback.
# Set exactly one of VIDEO_ANNOUNCE_STORY_AUTH_BUNDLE_ENV or VIDEO_ANNOUNCE_STORY_SESSION_ENV.
# If you point this to TELEGRAM_AUTH_BUNDLE_E2E / TELEGRAM_SESSION, do not reuse that session concurrently outside Kaggle.
# The chosen Telegram session still needs actual story capability; non-premium user sessions can fail preflight with PremiumAccountRequiredError.
# VIDEO_ANNOUNCE_STORY_ENABLED=0
# VIDEO_ANNOUNCE_STORY_REQUIRED=0
# VIDEO_ANNOUNCE_STORY_USE_MAIN_CHANNEL=0
# VIDEO_ANNOUNCE_STORY_AUTH_BUNDLE_ENV=TELEGRAM_AUTH_BUNDLE_S22
# VIDEO_ANNOUNCE_STORY_SESSION_ENV=TELEGRAM_SESSION
# VIDEO_ANNOUNCE_STORY_TARGETS_JSON=[{"peer":"@kenigevents","delay_seconds":0},{"peer":"@lovekenig","delay_seconds":600}]
# VIDEO_ANNOUNCE_STORY_EXTRA_TARGETS_JSON=[{"peer":"@kenigevents","delay_seconds":180}]
# VIDEO_ANNOUNCE_STORY_PERIOD_SECONDS=86400
# VIDEO_ANNOUNCE_STORY_CIPHER_DATASET=crumple-video-story-secrets-cipher
# VIDEO_ANNOUNCE_STORY_KEY_DATASET=crumple-video-story-secrets-key
# Optional: Telegram poster-cache rescue target. If set, this channel id is shipped inside the
# encrypted story auth payload and Kaggle can search there by filename when catbox/direct poster
# URLs are already dead. Without it, Kaggle falls back to Saved Messages for Telegram cache lookup.
# SOURCE_CHANNEL_ID=-1001234567890

# VK auto-import schedule (опционально)
ENABLE_VK_AUTO_IMPORT=0
VK_AUTO_IMPORT_TIMES_LOCAL=06:15,10:15,12:00,18:30
VK_AUTO_IMPORT_TZ=Europe/Kaliningrad
VK_AUTO_IMPORT_LIMIT=15
# Conservative default: process one row at a time; set to 1 only if N+1 prefetch is worth the extra RAM/lock-ahead.
# VK_AUTO_IMPORT_PREFETCH=0
# Cap heavy VK poster/photo processing inside auto-import without affecting other upload paths.
# VK_AUTO_IMPORT_MAX_PHOTOS=4
# Crash-recovery unlock budget for auto:* rows before terminal failed.
# VK_AUTO_IMPORT_RECOVERY_MAX_ATTEMPTS=3
# Max seconds per inbox row before auto-import marks that post as failed and continues.
# Set <=0 to disable the guard.
# VK_AUTO_IMPORT_ROW_TIMEOUT_SEC=1800
# VK_AUTO_IMPORT_MISFIRE_GRACE_SECONDS=1800
# VK_AUTO_IMPORT_CATCHUP_LOOKBACK_SECONDS=86400
# CRITICAL_SCHED_WATCHDOG_GRACE_SECONDS=300
# CRITICAL_SCHED_WATCHDOG_INTERVAL_SECONDS=60

# Ticket-sites queue schedule (опционально)
# Очередь собирает ticket‑URL из Telegram Monitoring постов и 1 раз в день обогащает события через Kaggle + Smart Update.
ENABLE_TICKET_SITES_QUEUE=0
TICKET_SITES_QUEUE_TIME_LOCAL=11:20
TICKET_SITES_QUEUE_TZ=Europe/Kaliningrad
# TICKET_SITES_QUEUE_LIMIT=25
# TICKET_SITES_QUEUE_INTERVAL_HOURS=24

# /v — автоматический production-first рендер "Завтра".
# Канонический slot: 16:00 local, чтобы worst-case timeout 225 минут и story fanout
# успевали завершиться до 21:00.
ENABLE_V_TOMORROW_SCHEDULED=0
V_TOMORROW_TIME_LOCAL=16:00
V_TOMORROW_TZ=Europe/Kaliningrad
V_TOMORROW_PROFILE=default
# Legacy alias route remains supported:
# ENABLE_V_TEST_TOMORROW_SCHEDULED=0
# V_TEST_TOMORROW_TIME_LOCAL=16:00
# V_TEST_TOMORROW_TZ=Europe/Kaliningrad
# V_TEST_TOMORROW_PROFILE=default
# Optional: force scheduled slot back into legacy test-render mode.
# V_TOMORROW_TEST_MODE=0
# VIDEO_KAGGLE_TIMEOUT_MINUTES=225
# Optional: publish `/v` stories directly from Kaggle after a successful render.
# Prefer explicit ordered targets for production fanout; `main`-channel order is only fallback.
# Set exactly one of VIDEO_ANNOUNCE_STORY_AUTH_BUNDLE_ENV or VIDEO_ANNOUNCE_STORY_SESSION_ENV.
# If you point this to TELEGRAM_AUTH_BUNDLE_S22 / TELEGRAM_SESSION, do not reuse that session concurrently outside Kaggle.
# VIDEO_ANNOUNCE_STORY_ENABLED=0
# VIDEO_ANNOUNCE_STORY_USE_MAIN_CHANNEL=0
# VIDEO_ANNOUNCE_STORY_AUTH_BUNDLE_ENV=TELEGRAM_AUTH_BUNDLE_S22
# VIDEO_ANNOUNCE_STORY_SESSION_ENV=TELEGRAM_SESSION
# VIDEO_ANNOUNCE_STORY_TARGETS_JSON=[{"peer":"@kenigevents","delay_seconds":0},{"peer":"@lovekenig","delay_seconds":600}]
# VIDEO_ANNOUNCE_STORY_PERIOD_SECONDS=86400
# VIDEO_ANNOUNCE_STORY_CIPHER_DATASET=crumple-video-story-secrets-cipher
# VIDEO_ANNOUNCE_STORY_KEY_DATASET=crumple-video-story-secrets-key

# Telegram Monitoring (Kaggle / Telethon) rate limit tuning (опционально)
# TG_MONITORING_DELAY_MIN=0.8
# TG_MONITORING_DELAY_MAX=2.2
# TG_MONITORING_SOURCE_PAUSE_MIN=2
# TG_MONITORING_SOURCE_PAUSE_MAX=6
# TG_MONITORING_FLOOD_SLEEP_THRESHOLD=600
# TG_MONITORING_FLOOD_WAIT_MAX=1800
# TG_MONITORING_FLOOD_MAX_RETRIES=4
# TG_MONITORING_FLOOD_WAIT_JITTER_MIN=6
# TG_MONITORING_FLOOD_WAIT_JITTER_MAX=18

# Post popularity analytics (TG/VK) (опционально)
# Baseline uses per-source median over the last N days for each age_day (days since publish).
# POST_POPULARITY_HORIZON_DAYS=90
# POST_POPULARITY_MIN_SAMPLE=20
# POST_POPULARITY_MAX_AGE_DAY=2
# Raise to 6 if you want mature /popular_posts 7-day snapshots instead of fallback to the latest available age_day<=6.
# POST_POPULARITY_VIEWS_MULT=1.5
# POST_POPULARITY_LIKES_MULT=1.5
# Multi-level markers ("super popular") — extra icons for stronger outliers:
# POST_POPULARITY_MAX_LEVEL=4
# POST_POPULARITY_VIEWS_STEP=0.5
# POST_POPULARITY_LIKES_STEP=0.5
# Retention for stored snapshots (defaults to POST_POPULARITY_HORIZON_DAYS if unset):
# POST_METRICS_RETENTION_DAYS=90

# Kaggle recovery (опционально, но полезно на проде)
# ENABLE_KAGGLE_RECOVERY=1
# KAGGLE_RECOVERY_INTERVAL_MINUTES=5

# Supabase (опционально; без него часть логов/фич отключится)
SUPABASE_URL=
SUPABASE_KEY=
# Для RPC (rate-limit gateway) обычно нужен service role:
# SUPABASE_SERVICE_KEY=
# Если RPC лежит не в `public`, выставьте схему (PostgREST Content-Profile):
# SUPABASE_SCHEMA=public
# SUPABASE_DISABLED=1
#
# Supabase Storage buckets
# Legacy single-bucket setup (current behavior):
# SUPABASE_BUCKET=events-ics
# Planned split buckets (requires code support; see docs/operations/supabase-storage.md):
# SUPABASE_ICS_BUCKET=events-ics
# SUPABASE_MEDIA_BUCKET=events-media
#
# Bucket usage guard (optional, best-effort):
# SUPABASE_BUCKET_USAGE_GUARD_MAX_USED_MB=490
# SUPABASE_BUCKET_USAGE_GUARD_CACHE_SEC=600
# SUPABASE_BUCKET_USAGE_GUARD_ON_ERROR=deny
#
# Server-side poster uploads (upload_images -> Supabase Storage):
# SUPABASE_POSTERS_PREFIX=p
# SUPABASE_POSTERS_WEBP_QUALITY=82
# When sharing one media bucket between PROD/TEST (different SQLite DBs), disable media deletes on TEST:
# SUPABASE_MEDIA_DELETE_ENABLED=1
#
# Telegram Monitoring videos in Supabase (Kaggle producer):
# TG_MONITORING_VIDEOS_SUPABASE_MODE=off
# TG_MONITORING_VIDEO_MAX_MB=10
# TG_MONITORING_VIDEO_BUCKET_SAFE_MB=430
# TG_MONITORING_VIDEOS_PREFIX=v
#
# Telegram Monitoring posters in Supabase (Kaggle producer):
# TG_MONITORING_POSTERS_SUPABASE_MODE=always
# TG_MONITORING_POSTERS_PREFIX=p
# TG_MONITORING_POSTERS_WEBP_QUALITY=82
#
# /3di (3D Preview) images in Supabase (Kaggle Preview3D):
# SUPABASE_PREVIEW3D_PREFIX=p3d
# Telegraph cover JPEG mirrors (server-side, best-effort):
# Used to keep the *first* Telegraph image preview-friendly for Telegram Instant View caching.
# SUPABASE_TELEGRAPH_COVER_PREFIX=tgcover
# TELEGRAPH_COVER_MIRROR_MAX_BYTES=8388608

# LLM gateway strict mode: если Supabase RPC недоступен (PGRST202), не делаем bypass на GOOGLE_API_KEY.
# GOOGLE_AI_ALLOW_RESERVE_FALLBACK=0

# Production Webhook (только для продакшена)
# WEBHOOK_URL=https://your-domain.com

# Optional settings
# DB_PATH=/data/db.sqlite

# Для тестирования с продакшн-данными локально:
# 1. Скачайте снимок БД: ./scripts/sync_prod_db.sh
# 2. Используйте снимок: DB_PATH=./db_prod_snapshot.sqlite
# 3. Запустите в режиме разработки: DEV_MODE=1

# PORT=8080
